{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "GI Health Check",
  "version": "0.1.0",
  "identifier": "com.idsolutions.gi-healthcheck",
  "build": {
    "frontendDist": "../build",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "GI Health Check",
      "width": 1024,
      "height": 720,
      "minWidth": 800,
      "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
